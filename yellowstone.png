.titulo_patrimonio{
    margin-top: 70px;
    margin-left: 30px;
    margin-right: 30px;
    line-height: 1.6;
    text-align:justify;

}

#pesquisa{
    margin-left: 30px;
    margin-bottom: 50px;
    width: 250px;
    padding: 10px;
    border: 2px solid gray;
}


.grade_patrimonios{
    display:grid;
    grid-template-columns:
      repeat(3, 1fr);
    gap:60px;
    width:90%;
    margin:0 auto;
}
 
.patrimonio_individual{
    text-align: center;
}

.patrimonio_individual img{
    width:300px;
    height:300px;
    border: 4px solid gray;
    object-fit:cover;
}

.patrimonio_individual p{
    margin-top:15px;
    font-size:27px;
    font-weight:bold;
}

.patrimonio_individual{
    text-decoration: none;
    color:black;
}

.patrimonio_individual:hover p{
    color: #324c5c;
}

